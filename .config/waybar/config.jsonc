{
  "layer": "top",
  "position": "top",
  "margin": "0 20 0 20",
  "fixed-center": true,
  "reload_style_on_change": true,
  "include": ["~/.config/waybar/modules.jsonc"],
  "modules-left": [
    "custom/arch",
    "cpu",
    "memory",
    "disk",
    "custom/updates"
  ],
  
  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "network#speed",
    "group/bluetooth",
    "clock"
    // "group/power"
  ],
}
