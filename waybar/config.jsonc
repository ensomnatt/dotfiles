{
  "layer": "top",
  "position": "top",
  "margin": "0 20 0 20",
  "fixed-center": true,
  "reload_style_on_change": true,
  "height": 45,
  "include": ["~/.config/waybar/modules.jsonc"],
  "modules-left": [
    "custom/arch",
    "hyprland/workspaces",
    "hyprland/window",
    "hyprland/language"
  ],
  
  "modules-center": [
    "mpris"
  ],

  "modules-right": [
    "pulseaudio",
    "cpu",
    "memory",
    "clock"
  ],
}
